generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client-quality"
}

datasource db {
  provider = "postgresql"
  url      = env("QUALITY_DATABASE_URL")
}

model ControlPlan {
  id              String   @id @default(uuid())
  tenantId        String   @default("default")
  sku             String
  name            String
  inspectionType  String   // INBOUND | IN_PROCESS | FINAL
  aqlLevel        String   @default("II") // I | II | III
  characteristics Json?    // checklist: [{ name, method, spec }]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  samples         AqlSample[]
  @@index([tenantId, sku, inspectionType])
}

model AqlSample {
  id             String      @id @default(uuid())
  tenantId       String      @default("default")
  controlPlanId  String
  controlPlan    ControlPlan @relation(fields: [controlPlanId], references: [id])
  referenceId    String?
  lotSize        Int
  sampleSize     Int
  inspected      Int         @default(0)
  defects        Int         @default(0)
  acceptNumber   Int
  rejectNumber   Int
  result         String      @default("PENDING") // PENDING | ACCEPT | REJECT
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  @@index([tenantId, controlPlanId, result])
}

model Inspection {
  id              String   @id @default(uuid())
  referenceId     String   // stores PO or WO number
  type            String   // INBOUND, IN_PROCESS, FINAL
  status          String   @default("PENDING") // PENDING, PASSED, FAILED
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NonConformanceReport {
  id                String   @id @default(uuid())
  tenantId          String   @default("default")
  inspectionId      String?
  defectCode        String?
  defectDescription String
  attachmentIds     String[] // Kody załączników z dms-service
  severity          String   // LOW, MEDIUM, HIGH, CRITICAL
  status            String   @default("OPEN") // OPEN | CLOSED
  disposition       String?
  projectId         String?
  workOrderId       String?
  bomComponentId    String?
  closedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([tenantId, status, projectId])
}

// CAPA — Corrective and Preventive Action (ISO 9001 §10.2), linked to NCR
// SPC — Statistical Process Control (X-bar charts, capability Cp/Cpk)
model SpcCharacteristic {
  id           String           @id @default(uuid())
  tenantId     String           @default("default")
  sku          String
  name         String
  unit         String           @default("mm")
  target       Float?
  usl          Float?           // Upper Spec Limit
  lsl          Float?           // Lower Spec Limit
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  measurements SpcMeasurement[]
  @@index([tenantId, sku])
}

model SpcMeasurement {
  id               String            @id @default(uuid())
  tenantId         String            @default("default")
  characteristicId String
  characteristic   SpcCharacteristic @relation(fields: [characteristicId], references: [id])
  value            Float
  operatorId       String?
  measuredAt       DateTime          @default(now())
  @@index([tenantId, characteristicId, measuredAt])
}

// ISO 9001 — rejestr dokumentacji systemu jakości
model IsoDocument {
  id           String    @id @default(uuid())
  tenantId     String    @default("default")
  code         String
  title        String
  clause       String    // np. §7.5, §8.5, §10.2
  version      String    @default("1.0")
  status       String    @default("ACTIVE") // DRAFT | ACTIVE | OBSOLETE
  reviewDue    DateTime?
  owner        String?
  fileRef      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@unique([tenantId, code, version])
  @@index([tenantId, clause, status])
}

model CapaAction {
  id           String    @id @default(uuid())
  tenantId     String    @default("default")
  ncrId        String
  type         String    @default("CORRECTIVE") // CORRECTIVE | PREVENTIVE
  description  String
  rootCause    String?
  assignee     String?
  dueDate      DateTime?
  status       String    @default("OPEN") // OPEN | IN_PROGRESS | DONE | VERIFIED
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@index([tenantId, ncrId, status])
}

enum OutboxStatus {
  PENDING
  PROCESSED
  FAILED
}

model OutboxEvent {
  id            String       @id @default(uuid())
  tenantId      String       @default("default")
  aggregateId   String
  aggregateType String
  eventType     String
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  lastError     String?
  createdAt     DateTime     @default(now())
  @@index([tenantId, status, createdAt])
}
