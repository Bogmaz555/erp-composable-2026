generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client-inv"
}
datasource db {
  provider = "postgresql"
  url = env("INVENTORY_DATABASE_URL")
}
model Item {
  id            String   @id @default(uuid())
  tenantId      String   @default("default")
  sku           String   @unique
  name          String
  description   String?
  type          String   @default("MATERIAL")
  stockQuantity Int      @default(0)
  stockLevels   StockLevel[]
  lots          Lot[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String?
  deletedAt     DateTime?
}

model StockLevel {
  id        String   @id @default(uuid())
  tenantId  String   @default("default")
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  quantity  Int
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId, itemId])
  @@index([location])
}

model Lot {
  id           String   @id @default(uuid())
  tenantId     String   @default("default")
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id])
  lotNumber    String
  serialNumber String?  @unique
  quantity     Int
  location     String?
  status       String   @default("AVAILABLE")
  createdAt    DateTime @default(now())
  createdBy    String?
  @@index([tenantId, itemId, status])
  @@index([serialNumber])
}

// Full Traceability support (Faza 1) - enhanced for ETO machine genealogy
model Reservation {
  id             String   @id @default(uuid())
  tenantId       String   @default("default")
  projectId      String?
  workOrderId    String?
  bomComponentId String?  // direct link to PLM BomComponent for "as-designed" traceability
  itemId         String
  lotId          String?
  quantity       Int
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  createdBy      String?
  releasedAt     DateTime?
  @@index([tenantId, projectId, itemId])
  @@index([workOrderId, status])
  @@index([bomComponentId])
}

model Requirement {
  id           String   @id @default(uuid())
  tenantId     String   @default("default")
  materialType String
  quantity     Int
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  createdBy    String?
}

// StockTransaction - immutable history log for all movements (critical for audit + genealogy)
model StockTransaction {
  id            String   @id @default(uuid())
  tenantId      String   @default("default")
  itemId        String
  lotId         String?
  type          String   // RECEIPT | ISSUE | RESERVATION | RELEASE | ADJUST | CONSUMPTION
  quantity      Int
  referenceType String?  // WORK_ORDER | PROJECT | PURCHASE_ORDER | BOM_RELEASE
  referenceId   String?
  notes         String?
  createdAt     DateTime @default(now())
  createdBy     String?
  @@index([tenantId, itemId, type, createdAt])
  @@index([referenceType, referenceId])
}

// ItemGenealogy - full forward/backward traceability (as-designed -> as-built -> as-maintained)
model ItemGenealogy {
  id                String   @id @default(uuid())
  tenantId          String   @default("default")
  parentSerialOrLot String   // e.g. finished machine serial number
  childItemId       String
  childLotId        String?
  quantityUsed      Float
  workOrderId       String?
  bomComponentId    String?  // link back to specific BOM line
  consumedAt        DateTime @default(now())
  @@index([tenantId, parentSerialOrLot])
  @@index([childLotId])
  @@index([workOrderId, bomComponentId])
}

model Warehouse {
  id        String       @id @default(uuid())
  tenantId  String       @default("default")
  code      String       @unique
  name      String
  bins      StorageBin[]
  createdAt DateTime     @default(now())
}

model StorageBin {
  id          String    @id @default(uuid())
  tenantId    String    @default("default")
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  code        String
  zone        String    @default("A")
  capacity    Int?
  @@unique([warehouseId, code])
  @@index([tenantId, zone])
}

model PickList {
  id         String     @id @default(uuid())
  tenantId   String     @default("default")
  pickNumber String     @unique
  projectId  String?
  status     String     @default("OPEN")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  lines      PickLine[]
  @@index([tenantId, status, projectId])
}

model PickLine {
  id         String   @id @default(uuid())
  pickListId String
  pickList   PickList @relation(fields: [pickListId], references: [id])
  itemId     String
  sku        String
  quantity   Int
  binCode    String?
  pickedQty  Int      @default(0)
  status     String   @default("PENDING")
  @@index([pickListId, status])
}

enum OutboxStatus {
  PENDING
  PROCESSED
  FAILED
}

model OutboxEvent {
  id            String       @id @default(uuid())
  tenantId      String       @default("default")
  aggregateId   String
  aggregateType String
  eventType     String
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  lastError     String?
  createdAt     DateTime     @default(now())
  processedAt   DateTime?
  @@index([tenantId, status, createdAt])
}
