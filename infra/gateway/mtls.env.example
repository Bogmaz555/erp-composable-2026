# Gateway mTLS dev profile (prod-security ext)
GATEWAY_MTLS=true
GATEWAY_MTLS_PORT=4445
GATEWAY_MTLS_PROXY=true
GATEWAY_MTLS_PROXY_PORT=4446
GATEWAY_MTLS_CLIENT_VERIFY=true
GATEWAY_MTLS_UPSTREAM=http://127.0.0.1:4005
GATEWAY_TLS_CERT=infra/tls/mtls/server.crt
GATEWAY_TLS_KEY=infra/tls/mtls/server.key
GATEWAY_TLS_CA=infra/tls/mtls/ca.crt
